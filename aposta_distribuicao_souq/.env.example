# Copie para `.env` e preencha. O `.env` está no .gitignore — nunca é versionado.

# --- Fonte de dados ---------------------------------------------------------
# "excel"    -> lê as planilhas de ..\dados (uso normal no SEU PC)
# "supabase" -> lê as tabelas aposta_* do Postgres (usado pelo app na nuvem)
FONTE_DADOS=excel

# Conexão do Supabase (use a string do POOLER — Settings > Database > Connection pooling).
# Necessária para publica_supabase.py (no PC) e para o app na nuvem (nos Secrets).
# É o MESMO banco do app de transferências; as tabelas daqui usam o prefixo aposta_.
# DATABASE_URL=postgresql+psycopg2://postgres.SEU_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres
