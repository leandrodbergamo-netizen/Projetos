# Fonte de dados: "mock" (exemplo, sem banco) ou "postgres"
FONTE_DADOS=mock

# Conexão PostgreSQL (usada quando FONTE_DADOS=postgres)
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/banco

# Data de referência ("hoje"). Deixe vazio em produção para usar a data atual.
DATA_REFERENCIA=2026-06-20
